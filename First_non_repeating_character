def first_non_repeating(s):
    freq = {}

    # Step 1: Count frequency
    for ch in s:
        if ch in freq:
            freq[ch] += 1
        else:
            freq[ch] = 1

    # Step 2: Find first non-repeating
    for ch in s:
        if freq[ch] == 1:
            return ch

    return "No non-repeating character"


print(first_non_repeating("programming"))

def second_largest(lst):
    if len(lst) < 2:
        return "No second largest"

    largest = second = float('-inf')

    for num in lst:
        if num > largest:
            second = largest
            largest = num
        elif num > second and num != largest:
            second = num

    if second == float('-inf'):
        return "No second largest"

    return second


print(second_largest([10, 20, 4, 45, 99]))
